{
    "title": "Aegis Flow PQC Metrics",
    "uid": "aegis-pqc",
    "panels": [
        {
            "type": "timeseries",
            "title": "PQC Handshake Duration",
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, rate(aegis_pqc_handshake_duration_seconds_bucket[5m]))"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Success Rate",
            "targets": [
                {
                    "expr": "rate(aegis_pqc_handshakes_total{success=\"true\"}[1m]) / rate(aegis_pqc_handshakes_total[1m])"
                }
            ]
        }
    ]
}